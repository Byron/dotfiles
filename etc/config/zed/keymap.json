[
  {
    "context": "Workspace",
    "bindings": {
      "alt-cmd-r": "task::Spawn",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-cmd-r": "task::Rerun",
    },
  },
  {
    "bindings": {
      "alt-enter": "workspace::ZoomIn",
    },
  },
  {
    "bindings": {
      "alt-`": "workspace::ToggleZoom",
    },
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "alt-enter": "editor::ToggleCodeActions",
    },
  },
  {
    "bindings": {
      "escape": "workspace::FocusCenterPane",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-cmd-k": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-r": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "AcpThread > Editor",
    "unbind": {
      "alt-cmd-k": "agent::ToggleThinkingMode",
    },
  },
  {
    "context": "Terminal",
    "unbind": {
      "alt-cmd-r": "terminal::RerunTask"
    }
  },
  {
    "context": "Workspace || Editor",
    "unbind": {
      "cmd-shift-k": "git::Push"
    }
  },
  {
    "context": "GitPanel",
    "unbind": {
      "ctrl-g up": "git::Push"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-shift-x": "terminal::ToggleViMode"
    }
  },
  {
    "context": "Terminal",
    "unbind": {
      "ctrl-shift-space": "terminal::ToggleViMode"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-cmd-n": "workspace::ToggleBottomDock"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-j": "workspace::ToggleBottomDock"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "cmd-shift-k": "editor::DeleteLine"
    }
  }
]
